{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id as user_id, u.display_name, SUM(s.points)::int as \"total!\"\n        FROM scores s\n        JOIN users u ON u.id = s.user_id\n        WHERE s.match_id = $1\n        GROUP BY u.id, u.display_name\n        ORDER BY \"total!\" DESC\n        LIMIT 50\n        ",
