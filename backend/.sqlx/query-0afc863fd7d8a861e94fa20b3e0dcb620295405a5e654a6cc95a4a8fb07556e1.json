{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT u.id as user_id, u.display_name, SUM(s.points)::bigint as total\n        FROM scores s\n        JOIN users u ON u.id = s.user_id\n        GROUP BY u.id, u.display_name\n        ORDER BY total DESC NULLS LAST\n        LIMIT $1\n        ",
